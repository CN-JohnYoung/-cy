// 获取卡牌实例归属玩家id
int gf_CardInstanceGetOwnerPlayerId(int lp_cardInstanceId)
{
    return gv_CardInstanceArray[lp_cardInstanceId].lv_ownerPlayerId;
}

// 获取玩家场上所有卡牌的普通单位总数量
int gf_PlayerGetFieldNormalUnitAmount(int lp_playerId)
{
    return gv_PlayerFieldNormalUnitAmount[lp_playerId];
}
